# Laravel API base URL — must end with /api
#
# Local (artisan serve):
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api
#
# Render production (Vercel → Environment Variables):
#   VITE_API_BASE_URL=https://zones-api.onrender.com/api
#
# Railway alternative:
#   VITE_API_BASE_URL=https://YOUR-SERVICE.up.railway.app/api
#
# See deploy/vercel.env.example and deploy/DEPLOY.md
#
# Herd (optional):
#   VITE_API_BASE_URL=http://zones-backend-laravel.test/api

VITE_API_BASE_URL=http://127.0.0.1:8000/api
