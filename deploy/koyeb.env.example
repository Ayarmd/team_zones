# =============================================================================
# Koyeb — Laravel API environment variables
# Copy values into: Koyeb → Service → Settings → Environment variables
# =============================================================================

APP_NAME=ZONES
APP_ENV=production
APP_DEBUG=false
# Generate locally: cd zones-backend-laravel && php artisan key:generate --show
APP_KEY=base64:REPLACE_ME

# After first deploy, set to your Koyeb public URL (no trailing slash)
# Example: https://zones-api-YOURORG.koyeb.app
APP_URL=https://YOUR-SERVICE.koyeb.app

# Vercel React URL (no trailing slash)
FRONTEND_URL=https://YOUR-APP.vercel.app
CORS_ALLOWED_ORIGINS=https://YOUR-APP.vercel.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Aiven MySQL (see deploy/aiven-mysql.env.example) ---
DB_CONNECTION=mysql
DB_HOST=YOUR-AIVEN-HOST.aivencloud.com
DB_PORT=12345
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=YOUR_AIVEN_PASSWORD

# Aiven requires TLS — download CA from Aiven console → Connection info → CA certificate
# Paste the PEM content on one line or mount as secret; Koyeb supports multiline secrets.
MYSQL_ATTR_SSL_CA=/var/www/html/storage/aiven-ca.pem

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

SANCTUM_STATEFUL_DOMAINS=YOUR-APP.vercel.app

MAIL_MAILER=log

# Optional: Google OAuth (Flutter / customer login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Koyeb sets PORT automatically — do not override unless documented
# PORT=8000
