# =============================================================================
# Aiven for MySQL — connection values for Laravel (Koyeb)
# Create service: Aiven Console → Create service → MySQL → Free/starter plan
# =============================================================================

# From Aiven → your MySQL service → Overview → Connection information

DB_CONNECTION=mysql
DB_HOST=mysql-xxxxxxxx.a.aivencloud.com
DB_PORT=12345
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=PASTE_SERVICE_PASSWORD

# SSL (required for Aiven public endpoints)
# 1. In Aiven → Connection information → download "CA certificate" (ca.pem)
# 2. On Koyeb: create a Secret file or paste into storage at deploy time
# 3. Set MYSQL_ATTR_SSL_CA to the path inside the container, e.g.:
MYSQL_ATTR_SSL_CA=/var/www/html/storage/aiven-ca.pem

# Alternative: use DB_URL (Laravel parses SSL from query string if configured)
# DB_URL=mysql://avnadmin:PASSWORD@HOST:PORT/defaultdb?ssl-mode=REQUIRED

# After Aiven is running, run migrations once (Koyeb entrypoint runs migrate --force on boot)

# Firewall: allow your Koyeb egress IPs or use "Public access" on Aiven
# (Aiven free tier: enable public internet access for the service)
