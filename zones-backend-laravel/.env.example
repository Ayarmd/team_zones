APP_NAME=ZONES
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# React web app (Vercel production URL, no trailing slash)
FRONTEND_URL=http://localhost:5173

# Extra CORS origins (comma-separated). FRONTEND_URL is added automatically.
# Example: https://team-zones.vercel.app,https://team-zones-git-main-ayarmd.vercel.app
CORS_ALLOWED_ORIGINS=

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Local (XAMPP / artisan serve) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zones
DB_USERNAME=root
DB_PASSWORD=

# --- Railway MySQL (set these in Railway Variables instead of local values) ---
# DB_CONNECTION=mysql
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://YOUR-SERVICE.up.railway.app
# FRONTEND_URL=https://YOUR-APP.vercel.app

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Include your Vercel domain for SPA cookie auth (Bearer tokens still work without this)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PLUTU_API_KEY=
PLUTU_ACCESS_TOKEN=
PLUTU_SECRET_KEY=
PLUTU_RETURN_URL="${APP_URL}/payment/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FIREBASE_CREDENTIALS=
FIREBASE_PROJECT_ID=zones-app

GOOGLE_CLIENT_ID=
