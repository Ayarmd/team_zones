# =============================================================================
# Railway — Laravel API + MySQL (FREE plan, no credit card to sign up)
# Docs: https://docs.railway.com/pricing/faqs
#
# Trial: $5 credit (30 days) → then Free plan: $1/month usage credit
# Enough for a small API OR API+MySQL if usage stays low.
# =============================================================================

APP_NAME=ZONES
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:REPLACE_ME

# After deploy: Railway → Service → Settings → Networking → Public URL
APP_URL=https://YOUR-SERVICE.up.railway.app

FRONTEND_URL=https://YOUR-APP.vercel.app
CORS_ALLOWED_ORIGINS=https://YOUR-APP.vercel.app
SANCTUM_STATEFUL_DOMAINS=YOUR-APP.vercel.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Option A: Railway MySQL plugin (recommended on Railway) ---
# Add MySQL from Railway project → Connect → use reference variables:
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# No SSL CA needed for internal Railway MySQL

# --- Option B: Aiven free MySQL (if DB is external) ---
# DB_HOST=mysql-xxxx.a.aivencloud.com
# DB_PORT=12345
# DB_DATABASE=defaultdb
# DB_USERNAME=avnadmin
# DB_PASSWORD=...
# MYSQL_ATTR_SSL_CA=/var/www/html/storage/aiven-ca.pem

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

MAIL_MAILER=log

# Railway service settings:
#   Root Directory: zones-backend-laravel
#   Builder: Dockerfile (uses Dockerfile + docker/entrypoint.sh)
#   OR Nixpacks (uses railway.toml startCommand — no background scheduler)
